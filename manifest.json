{
  "manifest_version": 3,
  "name": "StAige - AI Acting Coach",
  "version": "1.0",
  "description": "Get instant Gemini AI acting feedback on your monologues.",
  "permissions": [
    "storage",
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png.jpg"
  },
  "icons": {
    "16": "icon.png.jpg",
    "32": "icon.png.jpg",
    "48": "icon.png.jpg",
    "128": "icon.png.jpg"
  }
}
